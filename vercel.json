{
  "redirects": [
    {
      "source": "/auth/oauth-callback",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "extrack-pi.vercel.app"
        }
      ],
      "destination": "https://entrack.in/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.entrack.in"
        }
      ],
      "destination": "https://entrack.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
